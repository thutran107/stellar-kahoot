VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=3001
# Lock Socket.io CORS to your domain in production (e.g. https://yourdomain.com)
# Defaults to * (all origins) if not set
CORS_ORIGIN=
# Public URL players use to join — required in Dokploy so the QR code points to your domain
# e.g. https://kahoot.yourdomain.com
VITE_PUBLIC_URL=
